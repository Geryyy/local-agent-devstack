# Postgres
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=change_me

# Premium model credentials. Keep these on the workstation only.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Open WebUI can optionally reach vLLM through its OpenAI-compatible API when
# you start the optional profile.
OPENAI_API_BASE_URL=

# Default local inference path for the workstation stack.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LOCAL_MODEL=qwen2.5-coder:7b

# Optional vLLM profile.
# Pin away from `latest` so the optional stack does not jump to a newer CUDA
# requirement than the workstation driver supports.
VLLM_IMAGE=vllm/vllm-openai:v0.10.2
VLLM_MODEL_NAME=Qwen/Qwen3-Coder-30B-A3B-Instruct
VLLM_API_KEY=local-vllm-key
HUGGING_FACE_HUB_TOKEN=

# Internal service URLs for the agent API container.
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379/0
POSTGRES_URL=postgresql://agentuser:change_me@postgres:5432/agents

# Config file locations mounted into the agent API container.
AGENT_ROUTING_CONFIG=/configs/model-routing.yaml
AGENT_MODELS_CONFIG=/configs/models.yaml

# Tailscale / host naming used in docs and examples.
WORKSTATION_HOSTNAME=workstation

# Routing defaults. These values must match keys in configs/models.yaml.
DEFAULT_LOCAL_MODEL=qwen3_coder_local
DEFAULT_PREMIUM_MODEL=gpt_5_4
DEFAULT_REVIEW_MODEL=claude_opus
ENABLE_PREMIUM_ESCALATION=true
MAX_PREMIUM_CALLS_PER_RUN=3
