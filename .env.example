# Workstation endpoint reachable from the laptop in Phase 2.
WORKSTATION_HOST=WORKSTATION_HOST_OR_IP
WORKSTATION_USER=YOUR_WORKSTATION_USER

# Ollama runs natively on the workstation host in Phase 1.
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# Local tunnel port on the laptop host for Phase 2.
LOCAL_OLLAMA_PORT=11434

# Default local models for a balanced 16 GB workstation setup.
OLLAMA_CODE_MODEL=qwen2.5-coder:7b
OLLAMA_REASON_MODEL=qwen2.5:7b
OLLAMA_FALLBACK_MODEL=granite-code:8b

# Optional larger model path. Keep disabled unless you want to experiment.
OLLAMA_PULL_EXPERIMENTAL=false
OLLAMA_EXPERIMENTAL_MODEL=gpt-oss:20b

# Optional premium escalation. Keep unset unless you intentionally use OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=
