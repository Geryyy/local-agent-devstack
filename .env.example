# Workstation endpoint reachable from the laptop in Phase 2.
WORKSTATION_HOST=WORKSTATION_HOST_OR_IP
WORKSTATION_USER=YOUR_WORKSTATION_USER

# Ollama runs natively on the workstation host in Phase 1.
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# Local tunnel port on the laptop host for Phase 2.
LOCAL_OLLAMA_PORT=11434
# Safe default: host loopback only.
# For Linux devcontainers via host.docker.internal, set this to the Docker bridge IP
# or 0.0.0.0 before opening the tunnel if the container must reach the tunnel.
LOCAL_OLLAMA_BIND_HOST=127.0.0.1

# Default local models for a stronger workstation-first setup.
# Keep the 7B fallback so you still have a smaller option when latency matters.
OLLAMA_CODE_MODEL=gpt-oss:20b
OLLAMA_REASON_MODEL=gpt-oss:20b
OLLAMA_FALLBACK_MODEL=qwen2.5-coder:7b

# Optional larger model path. Keep disabled unless your workstation has the VRAM for it.
OLLAMA_PULL_EXPERIMENTAL=false
OLLAMA_EXPERIMENTAL_MODEL=qwen3-coder:30b

# Optional premium escalation. Keep unset unless you intentionally use OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=
